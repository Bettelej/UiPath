<Activity mc:Ignorable="sap sap2010" x:Class="Export_Folders" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_SourceBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_SourceToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Export Step 1 - Folders">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_ResponseJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_OutputPath" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="[UiPath.Core.LogLevel.Info]" Message="&quot;[Export Folders] Fetching all folders from source Orchestrator...&quot;" DisplayName="Log: Start" />

    <ui:InvokeWorkflowFile WorkflowFileName="Shared_OrchestratorApiCall.xaml" DisplayName="GET /odata/Folders">
      <ui:InvokeWorkflowFile.Arguments>
        <ArgumentCollection>
          <Argument Direction="In" Name="in_BaseUrl" Value="[in_SourceBaseUrl]" />
          <Argument Direction="In" Name="in_Token" Value="[in_SourceToken]" />
          <Argument Direction="In" Name="in_Endpoint" Value="&quot;/odata/Folders?$orderby=ParentId asc&quot;" />
          <Argument Direction="In" Name="in_Method" Value="&quot;GET&quot;" />
          <Argument Direction="In" Name="in_FolderId" Value="&quot;&quot;" />
          <Argument Direction="In" Name="in_RequestBody" Value="&quot;&quot;" />
          <Argument Direction="Out" Name="out_ResponseJson" Value="[v_ResponseJson]" />
          <Argument Direction="Out" Name="out_StatusCode" Value="[v_StatusCode]" />
        </ArgumentCollection>
      </ui:InvokeWorkflowFile.Arguments>
    </ui:InvokeWorkflowFile>

    <Assign DisplayName="Set Output Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_OutputPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Export_Folders.json")]</InArgument></Assign.Value>
    </Assign>

    <ui:InvokeCode Language="VB" DisplayName="Save Export_Folders.json">
      <ui:InvokeCode.Script>
        <![CDATA[
' Parse and pretty-print the folder array before saving
Dim folders As Newtonsoft.Json.Linq.JArray = Newtonsoft.Json.Linq.JArray.Parse(v_ResponseJson)
System.IO.File.WriteAllText(v_OutputPath,
    folders.ToString(Newtonsoft.Json.Formatting.Indented),
    System.Text.Encoding.UTF8)
        ]]>
      </ui:InvokeCode.Script>
    </ui:InvokeCode>

    <ui:LogMessage Level="[UiPath.Core.LogLevel.Info]" Message="[&quot;[Export Folders] Saved &quot; &amp; Newtonsoft.Json.Linq.JArray.Parse(v_ResponseJson).Count.ToString() &amp; &quot; folders to &quot; &amp; v_OutputPath]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
