<Activity mc:Ignorable="sap sap2010" x:Class="Import_Folders" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:nj="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 1 - Folders (Classic to Modern)">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_FoldersJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ConfigJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PageResponse" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
      <Variable x:TypeArguments="x:Int32" Name="v_Skip" Default="0" />
      <Variable x:TypeArguments="x:Boolean" Name="v_HasMore" Default="True" />
      <Variable x:TypeArguments="x:Int32" Name="v_PageCount" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_ExistingFoldersObj" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_IdMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_OldId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_DisplayName" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_TargetName" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_NewId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostBody" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostResponse" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_MappingPath" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Folders] Creating modern folders in target Orchestrator...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Folders.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FoldersJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Folders.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read MigrationConfig.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_ConfigJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText("MigrationConfig.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Mapping Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_MappingPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json")]</InArgument></Assign.Value>
    </Assign>

    <While DisplayName="Fetch Existing Target Folders">
      <While.Condition>[v_HasMore]</While.Condition>
      <Sequence DisplayName="Fetch One Page">
        <ui:OrchestratorHttpRequest DisplayName="GET /odata/Folders" Method="GET">
          <ui:OrchestratorHttpRequest.Endpoint>
            <InArgument x:TypeArguments="x:String">["/odata/Folders?$top=100&amp;$skip=" &amp; v_Skip.ToString()]</InArgument>
          </ui:OrchestratorHttpRequest.Endpoint>
          <ui:OrchestratorHttpRequest.Response>
            <OutArgument x:TypeArguments="x:String">[v_PageResponse]</OutArgument>
          </ui:OrchestratorHttpRequest.Response>
          <ui:OrchestratorHttpRequest.StatusCode>
            <OutArgument x:TypeArguments="x:Int32">[v_StatusCode]</OutArgument>
          </ui:OrchestratorHttpRequest.StatusCode>
        </ui:OrchestratorHttpRequest>
        <Assign DisplayName="Count page items">
          <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_PageCount]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:Int32">[If(JObject.Parse(v_PageResponse)("value") IsNot Nothing, DirectCast(JObject.Parse(v_PageResponse)("value"), JArray).Count, 0)]</InArgument></Assign.Value>
        </Assign>
        <Assign DisplayName="Merge into existing folders dict">
          <Assign.To><OutArgument x:TypeArguments="x:String">[v_ExistingFoldersObj]</OutArgument></Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">(Function()
    Dim dict As JObject = JObject.Parse(v_ExistingFoldersObj)
    Dim pageItems As JArray = TryCast(JObject.Parse(v_PageResponse)("value"), JArray)
    If pageItems IsNot Nothing Then
        For Each f As JObject In pageItems
            Dim fName As String = f("DisplayName").ToString()
            Dim fId As String = f("Id").ToString()
            If dict(fName) Is Nothing Then dict(fName) = fId
        Next
    End If
    Return dict.ToString()
End Function)()</InArgument>
          </Assign.Value>
        </Assign>
        <Assign DisplayName="Advance skip">
          <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_Skip]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:Int32">[v_Skip + 100]</InArgument></Assign.Value>
        </Assign>
        <Assign DisplayName="Set HasMore">
          <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_HasMore]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:Boolean">[v_PageCount = 100]</InArgument></Assign.Value>
        </Assign>
      </Sequence>
    </While>

    <ForEach x:TypeArguments="nj:JToken" DisplayName="ForEach Source Folder" Values="[JArray.Parse(v_FoldersJson)]">
      <ForEach.Body>
        <ActivityAction x:TypeArguments="nj:JToken">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="nj:JToken" Name="srcFolder" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Process Source Folder">
            <Assign DisplayName="Set OldId">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_OldId]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[srcFolder("Id").ToString()]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Set DisplayName">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_DisplayName]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[srcFolder("DisplayName").ToString()]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Compute TargetName (with mapping)">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetName]</OutArgument></Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="x:String">(Function()
    Dim cfg As JObject = JObject.Parse(v_ConfigJson)
    Dim mappings As JObject = TryCast(cfg("FolderMappings"), JObject)
    If mappings IsNot Nothing AndAlso mappings(v_DisplayName) IsNot Nothing Then
        Return mappings(v_DisplayName).ToString()
    End If
    Return v_DisplayName
End Function)()</InArgument>
              </Assign.Value>
            </Assign>
            <If DisplayName="If folder already exists in target">
              <If.Condition>[JObject.Parse(v_ExistingFoldersObj)(v_TargetName) IsNot Nothing]</If.Condition>
              <If.Then>
                <Sequence DisplayName="Use existing folder">
                  <Assign DisplayName="Get existing NewId">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_NewId]</OutArgument></Assign.To>
                    <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ExistingFoldersObj)(v_TargetName).ToString()]</InArgument></Assign.Value>
                  </Assign>
                  <Assign DisplayName="Add to IdMapping (existing)">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_IdMappingJson]</OutArgument></Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">(Function()
    Dim m As JObject = JObject.Parse(v_IdMappingJson)
    m(v_OldId) = v_NewId
    Return m.ToString()
End Function)()</InArgument>
                    </Assign.Value>
                  </Assign>
                  <ui:LogMessage Level="Info" Message="[&quot;[Import Folders] Skipping existing folder: &quot; &amp; v_TargetName &amp; &quot; (mapped &quot; &amp; v_OldId &amp; &quot; -&gt; &quot; &amp; v_NewId &amp; &quot;)&quot;]" DisplayName="Log: Folder Exists" />
                </Sequence>
              </If.Then>
              <If.Else>
                <Sequence DisplayName="Create new folder">
                  <Assign DisplayName="Build POST body">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_PostBody]</OutArgument></Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">(Function()
    Dim body As New JObject()
    body("DisplayName") = v_TargetName
    body("FullyQualifiedName") = v_TargetName
    body("Description") = If(srcFolder("Description") IsNot Nothing AndAlso srcFolder("Description").Type &lt;> JTokenType.Null, srcFolder("Description").ToString(), "")
    body("ProvisionType") = "Modern"
    body("PermissionModel") = "FineGrained"
    body("FeedType") = "FolderLevel"
    Return body.ToString()
End Function)()</InArgument>
                    </Assign.Value>
                  </Assign>
                  <ui:OrchestratorHttpRequest DisplayName="POST /odata/Folders" Method="POST">
                    <ui:OrchestratorHttpRequest.Endpoint>
                      <InArgument x:TypeArguments="x:String">"/odata/Folders"</InArgument>
                    </ui:OrchestratorHttpRequest.Endpoint>
                    <ui:OrchestratorHttpRequest.Body>
                      <InArgument x:TypeArguments="x:String">[v_PostBody]</InArgument>
                    </ui:OrchestratorHttpRequest.Body>
                    <ui:OrchestratorHttpRequest.Response>
                      <OutArgument x:TypeArguments="x:String">[v_PostResponse]</OutArgument>
                    </ui:OrchestratorHttpRequest.Response>
                    <ui:OrchestratorHttpRequest.StatusCode>
                      <OutArgument x:TypeArguments="x:Int32">[v_StatusCode]</OutArgument>
                    </ui:OrchestratorHttpRequest.StatusCode>
                  </ui:OrchestratorHttpRequest>
                  <If DisplayName="If POST succeeded">
                    <If.Condition>[v_StatusCode &gt;= 200 AndAlso v_StatusCode &lt; 300]</If.Condition>
                    <If.Then>
                      <Sequence DisplayName="Record new folder">
                        <Assign DisplayName="Extract NewId">
                          <Assign.To><OutArgument x:TypeArguments="x:String">[v_NewId]</OutArgument></Assign.To>
                          <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_PostResponse)("Id").ToString()]</InArgument></Assign.Value>
                        </Assign>
                        <Assign DisplayName="Add to IdMapping">
                          <Assign.To><OutArgument x:TypeArguments="x:String">[v_IdMappingJson]</OutArgument></Assign.To>
                          <Assign.Value>
                            <InArgument x:TypeArguments="x:String">(Function()
    Dim m As JObject = JObject.Parse(v_IdMappingJson)
    m(v_OldId) = v_NewId
    Return m.ToString()
End Function)()</InArgument>
                          </Assign.Value>
                        </Assign>
                        <Assign DisplayName="Add to ExistingFolders">
                          <Assign.To><OutArgument x:TypeArguments="x:String">[v_ExistingFoldersObj]</OutArgument></Assign.To>
                          <Assign.Value>
                            <InArgument x:TypeArguments="x:String">(Function()
    Dim obj As JObject = JObject.Parse(v_ExistingFoldersObj)
    obj(v_TargetName) = v_NewId
    Return obj.ToString()
End Function)()</InArgument>
                          </Assign.Value>
                        </Assign>
                        <ui:LogMessage Level="Info" Message="[&quot;[Import Folders] Created: &quot; &amp; v_TargetName &amp; &quot; (old=&quot; &amp; v_OldId &amp; &quot; new=&quot; &amp; v_NewId &amp; &quot;)&quot;]" DisplayName="Log: Folder Created" />
                      </Sequence>
                    </If.Then>
                    <If.Else>
                      <ui:LogMessage Level="Warn" Message="[&quot;[Import Folders] WARNING: Failed to create folder '&quot; &amp; v_TargetName &amp; &quot;': HTTP &quot; &amp; v_StatusCode.ToString() &amp; &quot; - &quot; &amp; v_PostResponse]" DisplayName="Log: Folder Failed" />
                    </If.Else>
                  </If>
                </Sequence>
              </If.Else>
            </If>
          </Sequence>
        </ActivityAction>
      </ForEach.Body>
    </ForEach>

    <Assign DisplayName="Save FolderIdMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    System.IO.File.WriteAllText(v_MappingPath, JObject.Parse(v_IdMappingJson).ToString(Formatting.Indented), System.Text.Encoding.UTF8)
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>
    <ui:LogMessage Level="Info" Message="[&quot;[Import Folders] FolderIdMapping.json saved to &quot; &amp; v_MappingPath]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>