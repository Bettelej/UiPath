<Activity mc:Ignorable="sap sap2010" x:Class="Import_Triggers" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:nj="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 8 - Triggers">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_TriggersJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ReleaseKeyMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_SrcFolderId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_TargetFolderId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_TriggerName" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostBody" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostResponse" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Triggers] Creating triggers (disabled) in target folders...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Triggers.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_TriggersJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Triggers.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read FolderIdMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderMappingJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read ReleaseKeyMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_ReleaseKeyMappingJson]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    Dim p As String = System.IO.Path.Combine(in_DataPath, "ReleaseKeyMapping.json")
    If System.IO.File.Exists(p) Then Return System.IO.File.ReadAllText(p)
    Return "{}"
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <ForEach x:TypeArguments="nj:JToken" DisplayName="ForEach Trigger" Values="[JArray.Parse(v_TriggersJson)]">
      <ForEach.Body>
        <ActivityAction x:TypeArguments="nj:JToken">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="nj:JToken" Name="triggerToken" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Process Trigger">
            <Assign DisplayName="Set SrcFolderId">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_SrcFolderId]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(triggerToken("_SourceFolderId") IsNot Nothing, triggerToken("_SourceFolderId").ToString(), "")]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Set TriggerName">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_TriggerName]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(triggerToken("Name") IsNot Nothing, triggerToken("Name").ToString(), "Trigger")]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Look up target folder ID">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetFolderId]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(JObject.Parse(v_FolderMappingJson)(v_SrcFolderId) IsNot Nothing, JObject.Parse(v_FolderMappingJson)(v_SrcFolderId).ToString(), "")]</InArgument></Assign.Value>
            </Assign>
            <If DisplayName="If folder mapped">
              <If.Condition>[Not String.IsNullOrEmpty(v_TargetFolderId)]</If.Condition>
              <If.Then>
                <Sequence DisplayName="Create trigger">
                  <Assign DisplayName="Build POST body">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_PostBody]</OutArgument></Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">(Function()
    Dim t As JObject = DirectCast(triggerToken, JObject)
    Dim body As New JObject()
    body("Name") = v_TriggerName
    body("Enabled") = False
    If t("StartProcessCron") IsNot Nothing AndAlso t("StartProcessCron").Type &lt;> JTokenType.Null Then
        body("StartProcessCron") = t("StartProcessCron").ToString()
    End If
    If t("TimeZoneId") IsNot Nothing AndAlso t("TimeZoneId").Type &lt;> JTokenType.Null Then
        body("TimeZoneId") = t("TimeZoneId").ToString()
    End If
    Dim oldKey As String = If(t("ReleaseKey") IsNot Nothing, t("ReleaseKey").ToString(), "")
    Dim keyMap As JObject = JObject.Parse(v_ReleaseKeyMappingJson)
    Dim newKey As String = If(Not String.IsNullOrEmpty(oldKey) AndAlso keyMap(oldKey) IsNot Nothing, keyMap(oldKey).ToString(), oldKey)
    If Not String.IsNullOrEmpty(newKey) Then body("ReleaseKey") = newKey
    Return body.ToString()
End Function)()</InArgument>
                    </Assign.Value>
                  </Assign>
                  <ui:OrchestratorHttpRequest DisplayName="POST /odata/ProcessSchedules" Method="POST">
                    <ui:OrchestratorHttpRequest.Endpoint>
                      <InArgument x:TypeArguments="x:String">"/odata/ProcessSchedules"</InArgument>
                    </ui:OrchestratorHttpRequest.Endpoint>
                    <ui:OrchestratorHttpRequest.Body>
                      <InArgument x:TypeArguments="x:String">[v_PostBody]</InArgument>
                    </ui:OrchestratorHttpRequest.Body>
                    <ui:OrchestratorHttpRequest.OrganizationUnitId>
                      <InArgument x:TypeArguments="x:Int64">[CLng(v_TargetFolderId)]</InArgument>
                    </ui:OrchestratorHttpRequest.OrganizationUnitId>
                    <ui:OrchestratorHttpRequest.Response>
                      <OutArgument x:TypeArguments="x:String">[v_PostResponse]</OutArgument>
                    </ui:OrchestratorHttpRequest.Response>
                    <ui:OrchestratorHttpRequest.StatusCode>
                      <OutArgument x:TypeArguments="x:Int32">[v_StatusCode]</OutArgument>
                    </ui:OrchestratorHttpRequest.StatusCode>
                  </ui:OrchestratorHttpRequest>
                  <If DisplayName="Log result">
                    <If.Condition>[v_StatusCode &gt;= 200 AndAlso v_StatusCode &lt; 300]</If.Condition>
                    <If.Then>
                      <ui:LogMessage Level="Info" Message="[&quot;[Import Triggers] Created (disabled) trigger: &quot; &amp; v_TriggerName]" DisplayName="Log: Trigger Created" />
                    </If.Then>
                    <If.Else>
                      <ui:LogMessage Level="Warn" Message="[&quot;[Import Triggers] WARNING: HTTP &quot; &amp; v_StatusCode.ToString() &amp; &quot; for trigger &apos;&quot; &amp; v_TriggerName &amp; &quot;&apos;: &quot; &amp; v_PostResponse]" DisplayName="Log: Trigger Failed" />
                    </If.Else>
                  </If>
                </Sequence>
              </If.Then>
              <If.Else>
                <ui:LogMessage Level="Warn" Message="[&quot;[Import Triggers] WARNING: No folder mapping for source folder &quot; &amp; v_SrcFolderId &amp; &quot;. Skipping: &quot; &amp; v_TriggerName]" DisplayName="Log: No Mapping" />
              </If.Else>
            </If>
          </Sequence>
        </ActivityAction>
      </ForEach.Body>
    </ForEach>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Triggers] Trigger import complete. Remember to enable triggers manually after validation.&quot;]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>