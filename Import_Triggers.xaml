<Activity mc:Ignorable="sap sap2010" x:Class="Import_Triggers" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
      <AssemblyReference>System.Private.Uri</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_TargetBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_TargetToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 8 - Triggers">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_TriggersJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ReleaseKeyMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Triggers] Creating process schedule triggers in target (all created as Disabled)...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Triggers.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_TriggersJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Triggers.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read FolderIdMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderMappingJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read ReleaseKeyMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_ReleaseKeyMappingJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "ReleaseKeyMapping.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="Create Triggers in Target (Disabled)">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    Dim triggers As JArray = JArray.Parse(v_TriggersJson)
    Dim folderIdMap As JObject = JObject.Parse(v_FolderMappingJson)
    Dim releaseKeyMap As JObject = JObject.Parse(v_ReleaseKeyMappingJson)

    Dim httpClient As New System.Net.Http.HttpClient()
    httpClient.Timeout = TimeSpan.FromSeconds(60)

    For Each trigger As JObject In triggers
        Dim srcFolderId As String = If(trigger("_SourceFolderId") IsNot Nothing, trigger("_SourceFolderId").ToString(), "")
        Dim triggerName As String = If(trigger("Name") IsNot Nothing, trigger("Name").ToString(), "UnnamedTrigger")
        Dim oldReleaseKey As String = If(trigger("ReleaseKey") IsNot Nothing, trigger("ReleaseKey").ToString(), "")

        Dim targetFolderId As String = ""
        If folderIdMap(srcFolderId) IsNot Nothing Then
            targetFolderId = folderIdMap(srcFolderId).ToString()
        Else
            Console.WriteLine("[Import Triggers] WARNING: No folder mapping for source folder " &amp; srcFolderId &amp; ". Skipping trigger: " &amp; triggerName)
            Continue For
        End If

        If String.IsNullOrEmpty(oldReleaseKey) OrElse releaseKeyMap(oldReleaseKey) Is Nothing Then
            Console.WriteLine("[Import Triggers] WARNING: No release key mapping for key '" &amp; oldReleaseKey &amp; "'. Skipping trigger: " &amp; triggerName)
            Continue For
        End If

        Dim newReleaseKey As String = releaseKeyMap(oldReleaseKey).ToString()

        Dim body As New JObject()
        body("Name") = triggerName
        body("ReleaseKey") = newReleaseKey
        body("Enabled") = False

        If trigger("StartProcessCron") IsNot Nothing AndAlso trigger("StartProcessCron").Type &lt;> JTokenType.Null Then
            body("StartProcessCron") = trigger("StartProcessCron").ToString()
        End If
        If trigger("TimeZoneId") IsNot Nothing AndAlso trigger("TimeZoneId").Type &lt;> JTokenType.Null Then
            body("TimeZoneId") = trigger("TimeZoneId").ToString()
        End If
        If trigger("StopStrategy") IsNot Nothing AndAlso trigger("StopStrategy").Type &lt;> JTokenType.Null Then
            body("StopStrategy") = trigger("StopStrategy").ToString()
        End If
        If trigger("KillJobsIfNotStopped") IsNot Nothing AndAlso trigger("KillJobsIfNotStopped").Type &lt;> JTokenType.Null Then
            body("KillJobsIfNotStopped") = CBool(trigger("KillJobsIfNotStopped"))
        End If
        If trigger("StopProcessingAfterMinutes") IsNot Nothing AndAlso trigger("StopProcessingAfterMinutes").Type &lt;> JTokenType.Null Then
            body("StopProcessingAfterMinutes") = CInt(trigger("StopProcessingAfterMinutes"))
        End If
        If trigger("MaxConcurrentJobs") IsNot Nothing AndAlso trigger("MaxConcurrentJobs").Type &lt;> JTokenType.Null Then
            body("MaxConcurrentJobs") = CInt(trigger("MaxConcurrentJobs"))
        End If
        If trigger("InputArguments") IsNot Nothing AndAlso trigger("InputArguments").Type &lt;> JTokenType.Null Then
            body("InputArguments") = trigger("InputArguments").ToString()
        End If
        If trigger("StartStrategy") IsNot Nothing AndAlso trigger("StartStrategy").Type &lt;> JTokenType.Null Then
            body("StartStrategy") = CInt(trigger("StartStrategy"))
        End If

        Dim postUrl As String = in_TargetBaseUrl.TrimEnd("/"c) &amp; "/odata/ProcessSchedules"
        Dim postReq As New System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Post, postUrl)
        postReq.Headers.TryAddWithoutValidation("Authorization", "Bearer " &amp; in_TargetToken)
        postReq.Headers.TryAddWithoutValidation("Accept", "application/json")
        postReq.Headers.TryAddWithoutValidation("X-UIPATH-OrganizationUnitId", targetFolderId)
        postReq.Content = New System.Net.Http.StringContent(body.ToString(), System.Text.Encoding.UTF8, "application/json")

        Dim postResp As System.Net.Http.HttpResponseMessage = httpClient.SendAsync(postReq).Result
        Dim postBody As String = postResp.Content.ReadAsStringAsync().Result

        If postResp.IsSuccessStatusCode Then
            Console.WriteLine("[Import Triggers] Created trigger (DISABLED): " &amp; triggerName)
        Else
            Console.WriteLine("[Import Triggers] WARNING: Failed to create trigger '" &amp; triggerName &amp;
                "': HTTP " &amp; CInt(postResp.StatusCode).ToString() &amp; " - " &amp; postBody)
        End If
    Next

    Console.WriteLine("[Import Triggers] IMPORTANT: All triggers were created as DISABLED. Enable them manually after verifying processes.")
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Triggers] Trigger import complete. All triggers are DISABLED - enable manually after verification.&quot;]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
