<Activity mc:Ignorable="sap sap2010" x:Class="Import_Environments" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:nj="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 2 - Environments to Subfolders">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_EnvsJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ConfigJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_EnvMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_EnvMappingPath" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostBody" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostResponse" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_EnvName" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ParentFolderId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Environments] Converting classic environments to modern subfolders...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Environments.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_EnvsJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Environments.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read FolderIdMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderMappingJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read MigrationConfig.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_ConfigJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText("MigrationConfig.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set EnvMappingPath">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_EnvMappingPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "EnvToSubfolderMapping.json")]</InArgument></Assign.Value>
    </Assign>

    <ForEach x:TypeArguments="nj:JToken" DisplayName="ForEach Environment" Values="[JArray.Parse(v_EnvsJson)]">
      <ForEach.Body>
        <ActivityAction x:TypeArguments="nj:JToken">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="nj:JToken" Name="envToken" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Process Environment">
            <Assign DisplayName="Set EnvName">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_EnvName]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[envToken("Name").ToString()]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Compute ParentFolderId">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_ParentFolderId]</OutArgument></Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="x:String">(Function()
    Dim cfg As JObject = JObject.Parse(v_ConfigJson)
    Dim envSubfolderConfig As JObject = TryCast(cfg("EnvironmentToSubfolderMappings"), JObject)
    If envSubfolderConfig IsNot Nothing AndAlso envSubfolderConfig(v_EnvName) IsNot Nothing Then
        Return envSubfolderConfig(v_EnvName).ToString()
    End If
    Dim folderMap As JObject = JObject.Parse(v_FolderMappingJson)
    For Each prop As JProperty In folderMap.Properties()
        Return prop.Value.ToString()
    Next
    Return ""
End Function)()</InArgument>
              </Assign.Value>
            </Assign>
            <If DisplayName="If ParentFolderId is set">
              <If.Condition>[Not String.IsNullOrEmpty(v_ParentFolderId)]</If.Condition>
              <If.Then>
                <Sequence DisplayName="Create subfolder">
                  <Assign DisplayName="Build POST body">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_PostBody]</OutArgument></Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">(Function()
    Dim body As New JObject()
    body("DisplayName") = v_EnvName
    body("FullyQualifiedName") = v_EnvName
    body("Description") = If(envToken("Description") IsNot Nothing AndAlso envToken("Description").Type &lt;> JTokenType.Null, envToken("Description").ToString(), "")
    body("ProvisionType") = "Manual"
    body("PermissionModel") = "InheritFromFolder"
    body("ParentId") = CInt(v_ParentFolderId)
    Return body.ToString()
End Function)()</InArgument>
                    </Assign.Value>
                  </Assign>
                  <ui:OrchestratorHttpRequest DisplayName="POST /odata/Folders (subfolder)" Method="POST">
                    <ui:OrchestratorHttpRequest.Endpoint>
                      <InArgument x:TypeArguments="x:String">"/odata/Folders"</InArgument>
                    </ui:OrchestratorHttpRequest.Endpoint>
                    <ui:OrchestratorHttpRequest.Body>
                      <InArgument x:TypeArguments="x:String">[v_PostBody]</InArgument>
                    </ui:OrchestratorHttpRequest.Body>
                    <ui:OrchestratorHttpRequest.Response>
                      <OutArgument x:TypeArguments="x:String">[v_PostResponse]</OutArgument>
                    </ui:OrchestratorHttpRequest.Response>
                    <ui:OrchestratorHttpRequest.StatusCode>
                      <OutArgument x:TypeArguments="x:Int32">[v_StatusCode]</OutArgument>
                    </ui:OrchestratorHttpRequest.StatusCode>
                  </ui:OrchestratorHttpRequest>
                  <If DisplayName="If POST succeeded">
                    <If.Condition>[v_StatusCode &gt;= 200 AndAlso v_StatusCode &lt; 300]</If.Condition>
                    <If.Then>
                      <Sequence DisplayName="Record subfolder">
                        <Assign DisplayName="Add to EnvMapping">
                          <Assign.To><OutArgument x:TypeArguments="x:String">[v_EnvMappingJson]</OutArgument></Assign.To>
                          <Assign.Value>
                            <InArgument x:TypeArguments="x:String">(Function()
    Dim m As JObject = JObject.Parse(v_EnvMappingJson)
    Dim newFolder As JObject = JObject.Parse(v_PostResponse)
    m(v_EnvName) = newFolder("Id").ToString()
    Return m.ToString()
End Function)()</InArgument>
                          </Assign.Value>
                        </Assign>
                        <ui:LogMessage Level="Info" Message="[&quot;[Import Environments] Created subfolder for env: &quot; &amp; v_EnvName]" DisplayName="Log: Subfolder Created" />
                      </Sequence>
                    </If.Then>
                    <If.Else>
                      <ui:LogMessage Level="Warn" Message="[&quot;[Import Environments] WARNING: Failed for env &apos;&quot; &amp; v_EnvName &amp; &quot;&apos;: HTTP &quot; &amp; v_StatusCode.ToString() &amp; &quot; - &quot; &amp; v_PostResponse]" DisplayName="Log: Subfolder Failed" />
                    </If.Else>
                  </If>
                </Sequence>
              </If.Then>
              <If.Else>
                <ui:LogMessage Level="Warn" Message="[&quot;[Import Environments] WARNING: No parent folder for env: &quot; &amp; v_EnvName &amp; &quot;. Skipping.&quot;]" DisplayName="Log: No Parent" />
              </If.Else>
            </If>
          </Sequence>
        </ActivityAction>
      </ForEach.Body>
    </ForEach>

    <Assign DisplayName="Save EnvToSubfolderMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    System.IO.File.WriteAllText(v_EnvMappingPath, JObject.Parse(v_EnvMappingJson).ToString(Formatting.Indented), System.Text.Encoding.UTF8)
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>
    <ui:LogMessage Level="Info" Message="[&quot;[Import Environments] EnvToSubfolderMapping.json saved to &quot; &amp; v_EnvMappingPath]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>