<Activity mc:Ignorable="sap sap2010" x:Class="Import_Packages" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_TargetBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_TargetToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 5 - Packages">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_PackagesDir" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="[UiPath.Core.LogLevel.Info]" Message="&quot;[Import Packages] Uploading .nupkg files to target Orchestrator...&quot;" DisplayName="Log: Start" />

    <Assign DisplayName="Set Packages Dir">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_PackagesDir]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Packages")]</InArgument></Assign.Value>
    </Assign>

    <!--
      [REPLACE] Upload each .nupkg to target via multipart/form-data POST.
      Endpoint: POST /odata/Processes/UiPath.Server.Configuration.OData.UploadPackage
      Content-Type: multipart/form-data
      Body: file field named "file" containing the .nupkg binary

      OPTION A - InvokeCode with HttpClient MultipartFormDataContent (shown below):
      OPTION B - PowerShell via InvokePowerShell with Invoke-RestMethod -Form @{file=...}
      OPTION C - UiPath WebAPI HTTP Client activity with multipart support
    -->
    <ui:InvokeCode Language="VB" DisplayName="[REPLACE] Upload Package .nupkg Files">
      <ui:InvokeCode.Script>
        <![CDATA[
If Not System.IO.Directory.Exists(v_PackagesDir) Then
    Console.WriteLine("[Import Packages] WARNING: Packages directory not found: " & v_PackagesDir)
    Return
End If

Dim nupkgFiles() As String = System.IO.Directory.GetFiles(v_PackagesDir, "*.nupkg")
If nupkgFiles.Length = 0 Then
    Console.WriteLine("[Import Packages] No .nupkg files found in " & v_PackagesDir)
    Return
End If

Dim httpClient As New System.Net.Http.HttpClient()
httpClient.Timeout = TimeSpan.FromMinutes(10)
httpClient.DefaultRequestHeaders.TryAddWithoutValidation("Authorization", "Bearer " & in_TargetToken)

Dim uploadUrl As String = in_TargetBaseUrl.TrimEnd("/"c) &
    "/odata/Processes/UiPath.Server.Configuration.OData.UploadPackage"

Dim uploaded As Integer = 0
Dim failed As Integer = 0

For Each nupkgPath As String In nupkgFiles
    Dim fileName As String = System.IO.Path.GetFileName(nupkgPath)
    Try
        Dim fileBytes() As Byte = System.IO.File.ReadAllBytes(nupkgPath)
        Dim fileContent As New System.Net.Http.ByteArrayContent(fileBytes)
        fileContent.Headers.ContentType = New System.Net.Http.Headers.MediaTypeHeaderValue(
            "application/octet-stream")

        Dim multipart As New System.Net.Http.MultipartFormDataContent()
        multipart.Add(fileContent, "file", fileName)

        Dim postResp As System.Net.Http.HttpResponseMessage = httpClient.PostAsync(uploadUrl, multipart).Result
        Dim postBody As String = postResp.Content.ReadAsStringAsync().Result

        If postResp.IsSuccessStatusCode Then
            Console.WriteLine("[Import Packages] Uploaded: " & fileName)
            uploaded += 1
        Else
            Console.WriteLine("[Import Packages] WARNING: Failed to upload '" & fileName &
                "': HTTP " & CInt(postResp.StatusCode).ToString() & " - " & postBody)
            failed += 1
        End If
    Catch ex As Exception
        Console.WriteLine("[Import Packages] ERROR uploading '" & fileName & "': " & ex.Message)
        failed += 1
    End Try
Next

Console.WriteLine("[Import Packages] Uploaded: " & uploaded & ", Failed: " & failed)
        ]]>
      </ui:InvokeCode.Script>
    </ui:InvokeCode>

    <ui:LogMessage Level="[UiPath.Core.LogLevel.Info]" Message="&quot;[Import Packages] Package upload complete.&quot;" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
