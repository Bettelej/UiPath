<Activity mc:Ignorable="sap sap2010" x:Class="Import_Packages" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 5 - Packages">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_FilesDir" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FilesExist" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Packages] Checking for .nupkg files to upload...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Set Files Dir">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FilesDir]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Packages")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Check files exist">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FilesExist]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(System.IO.Directory.Exists(v_FilesDir) AndAlso System.IO.Directory.GetFiles(v_FilesDir, "*.nupkg").Length > 0, "yes", "no")]</InArgument></Assign.Value>
    </Assign>

    <If DisplayName="If .nupkg files found">
      <If.Condition>[v_FilesExist = "yes"]</If.Condition>
      <If.Then>
        <ui:LogMessage Level="Warn" Message="[&quot;[Import Packages] Found .nupkg files in &quot; &amp; v_FilesDir &amp; &quot;. NOTE: Automatic upload via OrchestratorHttpRequest is not supported for binary/multipart uploads. Please upload packages manually via the Orchestrator web UI (Tenant &gt; Packages) or use the UiPath CLI nuget push command.&quot;]" DisplayName="Log: Manual Upload Required" />
      </If.Then>
      <If.Else>
        <ui:LogMessage Level="Warn" Message="[&quot;[Import Packages] No .nupkg files found in &quot; &amp; v_FilesDir &amp; &quot;. If packages need to be migrated, please manually download from source Orchestrator and upload to target via the web UI.&quot;]" DisplayName="Log: No Files Found" />
      </If.Else>
    </If>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Packages] Step complete (manual action may be required - see warnings above).&quot;]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>