<Activity mc:Ignorable="sap sap2010" x:Class="Main" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:s="clr-namespace:System;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>System.Linq</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
      <x:String>UiPath.Core.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
      <AssemblyReference>UiPath.UiAutomation.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Main - Orchestrator Migration" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_ErrorMessage" Default="&quot;&quot;" />
    </Sequence.Variables>
    <TryCatch DisplayName="Migration TryCatch">
      <TryCatch.Try>
        <Sequence DisplayName="Migration Steps">
          <Sequence.Variables>
            <Variable x:TypeArguments="x:String" Name="v_ConfigJson" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_SourceBaseUrl" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_SourceToken" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_SourceAuthType" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_SourceApiKey" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_SourceUsername" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_SourcePassword" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_TargetBaseUrl" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_TargetToken" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_TargetClientId" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_TargetClientSecret" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_TargetIdentityUrl" Default="&quot;&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_DataPath" Default="&quot;Data&quot;" />
            <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
          </Sequence.Variables>

          <!-- Step 0: Log start -->
          <ui:LogMessage Level="Info" Message="[&quot;[Migration] Starting Orchestrator migration. Loading configuration...&quot;]" DisplayName="Log: Start" />

          <!-- Step 0a: Load MigrationConfig.json using Assign activities -->
          <Assign DisplayName="Read MigrationConfig.json">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_ConfigJson]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText("MigrationConfig.json")]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse SourceBaseUrl">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_SourceBaseUrl]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("Source")("BaseUrl").ToString().TrimEnd("/"c)]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse SourceAuthType">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_SourceAuthType]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("Source")("AuthType").ToString()]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse SourceApiKey">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_SourceApiKey]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[If(JObject.Parse(v_ConfigJson)("Source")("ApiKey") IsNot Nothing, JObject.Parse(v_ConfigJson)("Source")("ApiKey").ToString(), "")]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse SourceUsername">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_SourceUsername]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[If(JObject.Parse(v_ConfigJson)("Source")("Username") IsNot Nothing, JObject.Parse(v_ConfigJson)("Source")("Username").ToString(), "")]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse SourcePassword">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_SourcePassword]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[If(JObject.Parse(v_ConfigJson)("Source")("Password") IsNot Nothing, JObject.Parse(v_ConfigJson)("Source")("Password").ToString(), "")]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse TargetBaseUrl">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetBaseUrl]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("Target")("BaseUrl").ToString().TrimEnd("/"c)]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse TargetClientId">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetClientId]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("Target")("ClientId").ToString()]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse TargetClientSecret">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetClientSecret]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("Target")("ClientSecret").ToString()]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse TargetIdentityUrl">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetIdentityUrl]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("Target")("IdentityServerUrl").ToString().TrimEnd("/"c)]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Parse DataPath">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_DataPath]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[JObject.Parse(v_ConfigJson)("DataPath").ToString()]</InArgument></Assign.Value>
          </Assign>

          <!-- Step 0b: Create Data directories using Assign side-effects -->
          <Assign DisplayName="Create DataPath directory">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Directory.CreateDirectory(v_DataPath).FullName]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Create Packages subdirectory">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Directory.CreateDirectory(System.IO.Path.Combine(v_DataPath, "Packages")).FullName]</InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="Create Libraries subdirectory">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Directory.CreateDirectory(System.IO.Path.Combine(v_DataPath, "Libraries")).FullName]</InArgument></Assign.Value>
          </Assign>

          <!-- Step 0c: Authenticate against Source Orchestrator -->
          <ui:LogMessage Level="Info" Message="[&quot;[Migration] Authenticating against source Orchestrator...&quot;]" DisplayName="Log: Auth Source" />
          <ui:InvokeWorkflowFile WorkflowFileName="Auth_Source.xaml" DisplayName="Get Source Token">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_AuthType">[v_SourceAuthType]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_ApiKey">[v_SourceApiKey]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_Username">[v_SourceUsername]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_Password">[v_SourcePassword]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_BaseUrl">[v_SourceBaseUrl]</InArgument>
                <OutArgument x:TypeArguments="x:String" x:Key="out_Token">[v_SourceToken]</OutArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <!-- Step 0d: Authenticate against Target Orchestrator (OAuth) -->
          <ui:LogMessage Level="Info" Message="[&quot;[Migration] Authenticating against target Orchestrator (OAuth)...&quot;]" DisplayName="Log: Auth Target" />
          <ui:InvokeWorkflowFile WorkflowFileName="Auth_Target.xaml" DisplayName="Get Target Token (OAuth)">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_ClientId">[v_TargetClientId]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_ClientSecret">[v_TargetClientSecret]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_IdentityUrl">[v_TargetIdentityUrl]</InArgument>
                <OutArgument x:TypeArguments="x:String" x:Key="out_Token">[v_TargetToken]</OutArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:LogMessage Level="Info" Message="[&quot;[Migration] Authentication successful. Starting EXPORT phase...&quot;]" DisplayName="Log: Export Phase Start" />

          <!-- EXPORT PHASE -->
          <ui:InvokeWorkflowFile WorkflowFileName="Export_Folders.xaml" DisplayName="Step 1 - Export Folders">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Environments.xaml" DisplayName="Step 2 - Export Environments">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Assets.xaml" DisplayName="Step 3 - Export Assets">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Queues.xaml" DisplayName="Step 4 - Export Queues">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Packages.xaml" DisplayName="Step 5 - Export Packages">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Libraries.xaml" DisplayName="Step 6 - Export Libraries">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Processes.xaml" DisplayName="Step 7 - Export Processes">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Export_Triggers.xaml" DisplayName="Step 8 - Export Triggers">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceBaseUrl">[v_SourceBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_SourceToken">[v_SourceToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:LogMessage Level="Info" Message="[&quot;[Migration] EXPORT phase complete. Starting IMPORT phase...&quot;]" DisplayName="Log: Import Phase Start" />

          <!-- IMPORT PHASE -->
          <ui:InvokeWorkflowFile WorkflowFileName="Import_Folders.xaml" DisplayName="Step 1 - Import Folders">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_ConfigJson">[v_ConfigJson]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Environments.xaml" DisplayName="Step 2 - Import Environments as Subfolders">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_ConfigJson">[v_ConfigJson]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Assets.xaml" DisplayName="Step 3 - Import Assets">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Queues.xaml" DisplayName="Step 4 - Import Queues">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Packages.xaml" DisplayName="Step 5 - Import Packages">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Libraries.xaml" DisplayName="Step 6 - Import Libraries">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Processes.xaml" DisplayName="Step 7 - Import Processes">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:InvokeWorkflowFile WorkflowFileName="Import_Triggers.xaml" DisplayName="Step 8 - Import Triggers">
            <ui:InvokeWorkflowFile.Arguments>
              <scg:Dictionary x:TypeArguments="x:String, Argument">
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetBaseUrl">[v_TargetBaseUrl]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_TargetToken">[v_TargetToken]</InArgument>
                <InArgument x:TypeArguments="x:String" x:Key="in_DataPath">[v_DataPath]</InArgument>
              </scg:Dictionary>
            </ui:InvokeWorkflowFile.Arguments>
          </ui:InvokeWorkflowFile>

          <ui:LogMessage Level="Info" Message="[&quot;[Migration] IMPORT phase complete. Migration finished successfully!&quot;]" DisplayName="Log: Migration Complete" />
          <ui:LogMessage Level="Info" Message="[&quot;[Migration] IMPORTANT: Manual steps required - see CredentialReport_ManualAction.json and enable triggers manually.&quot;]" DisplayName="Log: Manual Steps Reminder" />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="migrationException" />
            </ActivityAction.Argument>
            <Sequence DisplayName="Handle Migration Error">
              <Assign DisplayName="Set Error Message">
                <Assign.To><OutArgument x:TypeArguments="x:String">[v_ErrorMessage]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">[migrationException.Message]</InArgument></Assign.Value>
              </Assign>
              <ui:LogMessage Level="Error" Message="[&quot;[Migration] FATAL ERROR: &quot; &amp; v_ErrorMessage]" DisplayName="Log: Fatal Error" />
              <Rethrow />
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>
  </Sequence>
</Activity>
