<Activity mc:Ignorable="sap sap2010" x:Class="Export_Triggers" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
      <AssemblyReference>System.Private.Uri</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_SourceBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_SourceToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Export Step 8 - Triggers">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_FoldersJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_OutputPath" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_AllTriggersJson" Default="&quot;[]&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Export Triggers] Reading folder list and fetching process schedules per folder...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Folders.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FoldersJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Folders.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="Fetch Triggers Per Folder">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_AllTriggersJson]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
Dim folders As JArray = JArray.Parse(v_FoldersJson)
Dim allItems As New JArray()
Dim httpClient As New System.Net.Http.HttpClient()
httpClient.Timeout = TimeSpan.FromSeconds(60)

For Each folder As JObject In folders
    Dim folderId As String = folder("Id").ToString()
    Dim folderName As String = If(folder("FullyQualifiedName") IsNot Nothing AndAlso
        folder("FullyQualifiedName").Type &lt;> JTokenType.Null,
        folder("FullyQualifiedName").ToString(),
        folder("DisplayName").ToString())

    Dim skip As Integer = 0
    Dim top As Integer = 100
    Dim hasMore As Boolean = True

    Do While hasMore
        Dim url As String = in_SourceBaseUrl.TrimEnd("/"c) &amp;
            "/odata/ProcessSchedules?$top=" &amp; top &amp; "&amp;$skip=" &amp; skip
        Dim request As New System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Get, url)
        request.Headers.TryAddWithoutValidation("Authorization", "Bearer " &amp; in_SourceToken)
        request.Headers.TryAddWithoutValidation("Accept", "application/json")
        request.Headers.TryAddWithoutValidation("X-UIPATH-OrganizationUnitId", folderId)

        Dim resp As System.Net.Http.HttpResponseMessage = httpClient.SendAsync(request).Result
        If Not resp.IsSuccessStatusCode Then
            hasMore = False
            Continue Do
        End If

        Dim body As String = resp.Content.ReadAsStringAsync().Result
        Dim obj As JObject = JObject.Parse(body)
        Dim items As JArray = TryCast(obj("value"), JArray)

        If items Is Nothing OrElse items.Count = 0 Then
            hasMore = False
        Else
            For Each item As JObject In items
                item("_SourceFolderId") = folderId
                item("_SourceFolderName") = folderName
                allItems.Add(item)
            Next
            skip += top
            If items.Count &lt; top Then hasMore = False
        End If
    Loop
Next

Return allItems.ToString(Formatting.Indented)
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <Assign DisplayName="Set Output Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_OutputPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Export_Triggers.json")]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="Save Export_Triggers.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    System.IO.File.WriteAllText(v_OutputPath, v_AllTriggersJson, System.Text.Encoding.UTF8)
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info" Message="[&quot;[Export Triggers] Saved &quot; &amp; Newtonsoft.Json.Linq.JArray.Parse(v_AllTriggersJson).Count.ToString() &amp; &quot; triggers to &quot; &amp; v_OutputPath]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
