<Activity mc:Ignorable="sap sap2010" x:Class="Import_Processes" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:nj="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 7 - Processes (Releases)">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_ProcessesJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ReleaseKeyMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_SrcFolderId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_TargetFolderId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_ReleaseName" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_OldKey" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostBody" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PostResponse" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Processes] Creating releases in target folders...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Processes.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_ProcessesJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Processes.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read FolderIdMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderMappingJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>

    <ForEach x:TypeArguments="nj:JToken" DisplayName="ForEach Release" Values="[JArray.Parse(v_ProcessesJson)]">
      <ForEach.Body>
        <ActivityAction x:TypeArguments="nj:JToken">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="nj:JToken" Name="procToken" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Process Release">
            <Assign DisplayName="Set SrcFolderId">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_SrcFolderId]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(procToken("_SourceFolderId") IsNot Nothing, procToken("_SourceFolderId").ToString(), "")]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Set ReleaseName">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_ReleaseName]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[procToken("Name").ToString()]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Set OldKey">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_OldKey]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(procToken("Key") IsNot Nothing, procToken("Key").ToString(), "")]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Look up target folder ID">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_TargetFolderId]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(JObject.Parse(v_FolderMappingJson)(v_SrcFolderId) IsNot Nothing, JObject.Parse(v_FolderMappingJson)(v_SrcFolderId).ToString(), "")]</InArgument></Assign.Value>
            </Assign>
            <If DisplayName="If folder mapped">
              <If.Condition>[Not String.IsNullOrEmpty(v_TargetFolderId)]</If.Condition>
              <If.Then>
                <Sequence DisplayName="Create release">
                  <Assign DisplayName="Build POST body">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_PostBody]</OutArgument></Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">(Function()
    Dim proc As JObject = DirectCast(procToken, JObject)
    Dim body As New JObject()
    body("Name") = v_ReleaseName
    body("ProcessKey") = If(proc("ProcessKey") IsNot Nothing, proc("ProcessKey").ToString(), "")
    body("ProcessVersion") = If(proc("ProcessVersion") IsNot Nothing, proc("ProcessVersion").ToString(), "")
    body("Description") = If(proc("Description") IsNot Nothing AndAlso proc("Description").Type &lt;> JTokenType.Null, proc("Description").ToString(), "")
    body("AutoUpdate") = False
    If proc("EntryPointPath") IsNot Nothing AndAlso proc("EntryPointPath").Type &lt;> JTokenType.Null Then
        body("EntryPointPath") = proc("EntryPointPath").ToString()
    End If
    Return body.ToString()
End Function)()</InArgument>
                    </Assign.Value>
                  </Assign>
                  <ui:OrchestratorHttpRequest DisplayName="POST /odata/Releases" Method="POST">
                    <ui:OrchestratorHttpRequest.Endpoint>
                      <InArgument x:TypeArguments="x:String">"/odata/Releases"</InArgument>
                    </ui:OrchestratorHttpRequest.Endpoint>
                    <ui:OrchestratorHttpRequest.Body>
                      <InArgument x:TypeArguments="x:String">[v_PostBody]</InArgument>
                    </ui:OrchestratorHttpRequest.Body>
                    <ui:OrchestratorHttpRequest.OrganizationUnitId>
                      <InArgument x:TypeArguments="x:Int64">[CLng(v_TargetFolderId)]</InArgument>
                    </ui:OrchestratorHttpRequest.OrganizationUnitId>
                    <ui:OrchestratorHttpRequest.Response>
                      <OutArgument x:TypeArguments="x:String">[v_PostResponse]</OutArgument>
                    </ui:OrchestratorHttpRequest.Response>
                    <ui:OrchestratorHttpRequest.StatusCode>
                      <OutArgument x:TypeArguments="x:Int32">[v_StatusCode]</OutArgument>
                    </ui:OrchestratorHttpRequest.StatusCode>
                  </ui:OrchestratorHttpRequest>
                  <If DisplayName="If POST succeeded">
                    <If.Condition>[v_StatusCode &gt;= 200 AndAlso v_StatusCode &lt; 300]</If.Condition>
                    <If.Then>
                      <Sequence DisplayName="Record key mapping">
                        <Assign DisplayName="Add to ReleaseKeyMapping">
                          <Assign.To><OutArgument x:TypeArguments="x:String">[v_ReleaseKeyMappingJson]</OutArgument></Assign.To>
                          <Assign.Value>
                            <InArgument x:TypeArguments="x:String">(Function()
    Dim m As JObject = JObject.Parse(v_ReleaseKeyMappingJson)
    Dim newRelease As JObject = JObject.Parse(v_PostResponse)
    Dim newKey As String = If(newRelease("Key") IsNot Nothing, newRelease("Key").ToString(), "")
    If Not String.IsNullOrEmpty(v_OldKey) AndAlso Not String.IsNullOrEmpty(newKey) Then
        m(v_OldKey) = newKey
    End If
    Return m.ToString()
End Function)()</InArgument>
                          </Assign.Value>
                        </Assign>
                        <ui:LogMessage Level="Info" Message="[&quot;[Import Processes] Created release: &quot; &amp; v_ReleaseName]" DisplayName="Log: Release Created" />
                      </Sequence>
                    </If.Then>
                    <If.Else>
                      <ui:LogMessage Level="Warn" Message="[&quot;[Import Processes] WARNING: Failed to create release &apos;&quot; &amp; v_ReleaseName &amp; &quot;&apos;: HTTP &quot; &amp; v_StatusCode.ToString() &amp; &quot; - &quot; &amp; v_PostResponse]" DisplayName="Log: Release Failed" />
                    </If.Else>
                  </If>
                </Sequence>
              </If.Then>
              <If.Else>
                <ui:LogMessage Level="Warn" Message="[&quot;[Import Processes] WARNING: No folder mapping for source folder &quot; &amp; v_SrcFolderId &amp; &quot;. Skipping: &quot; &amp; v_ReleaseName]" DisplayName="Log: No Mapping" />
              </If.Else>
            </If>
          </Sequence>
        </ActivityAction>
      </ForEach.Body>
    </ForEach>

    <Assign DisplayName="Save ReleaseKeyMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    Dim mappingPath As String = System.IO.Path.Combine(in_DataPath, "ReleaseKeyMapping.json")
    System.IO.File.WriteAllText(mappingPath, JObject.Parse(v_ReleaseKeyMappingJson).ToString(Formatting.Indented), System.Text.Encoding.UTF8)
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>
    <ui:LogMessage Level="Info" Message="[&quot;[Import Processes] Releases import complete. ReleaseKeyMapping.json saved.&quot;]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>