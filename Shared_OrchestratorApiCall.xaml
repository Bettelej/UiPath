<Activity mc:Ignorable="sap sap2010" x:Class="Shared_OrchestratorApiCall" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:s="clr-namespace:System;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
      <x:String>UiPath.Core.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
      <AssemblyReference>System.Private.Uri</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_BaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_Token" Type="InArgument(x:String)" />
    <x:Property Name="in_Endpoint" Type="InArgument(x:String)" />
    <x:Property Name="in_Method" Type="InArgument(x:String)" />
    <x:Property Name="in_FolderId" Type="InArgument(x:String)" />
    <x:Property Name="in_RequestBody" Type="InArgument(x:String)" />
    <x:Property Name="out_ResponseJson" Type="OutArgument(x:String)" />
    <x:Property Name="out_StatusCode" Type="OutArgument(x:Int32)" />
  </x:Members>
  <Sequence DisplayName="Shared - Orchestrator API Call" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:Int32" Name="v_RetryCount" Default="0" />
      <Variable x:TypeArguments="x:Boolean" Name="v_Success" Default="False" />
      <Variable x:TypeArguments="x:String" Name="v_LastError" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_Skip" Default="0" />
      <Variable x:TypeArguments="x:Boolean" Name="v_HasMore" Default="True" />
      <Variable x:TypeArguments="x:String" Name="v_AllItemsJson" Default="&quot;[]&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Url" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_CombinedResult" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_LastBody" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_LastStatus" Default="0" />
      <Variable x:TypeArguments="x:Int32" Name="v_PageCount" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <While DisplayName="Retry Loop (max 3 attempts)">
      <While.Condition>[v_RetryCount &lt; 3 AndAlso Not v_Success]</While.Condition>
      <Sequence DisplayName="Attempt API Call">
        <Assign DisplayName="Increment Retry Counter">
          <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_RetryCount]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:Int32">[v_RetryCount + 1]</InArgument></Assign.Value>
        </Assign>
        <TryCatch DisplayName="TryCatch - API Attempt">
          <TryCatch.Try>
            <Sequence DisplayName="Execute HTTP Request">
              <Assign DisplayName="Reset pagination">
                <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_Skip]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Int32">0</InArgument></Assign.Value>
              </Assign>
              <Assign DisplayName="Reset hasMore">
                <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_HasMore]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Boolean">True</InArgument></Assign.Value>
              </Assign>
              <Assign DisplayName="Reset allItems">
                <Assign.To><OutArgument x:TypeArguments="x:String">[v_AllItemsJson]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">"[]"</InArgument></Assign.Value>
              </Assign>

              <While DisplayName="Pagination Loop">
                <While.Condition>[v_HasMore]</While.Condition>
                <Sequence DisplayName="Single Page Request">

                  <Assign DisplayName="Build URL">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_Url]</OutArgument></Assign.To>
                    <Assign.Value><InArgument x:TypeArguments="x:String">[If(in_Method.ToUpper() = "GET", in_BaseUrl.TrimEnd("/"c) &amp; in_Endpoint &amp; If(in_Endpoint.Contains("?"), "&amp;", "?") &amp; "$top=100&amp;$skip=" &amp; v_Skip.ToString(), in_BaseUrl.TrimEnd("/"c) &amp; in_Endpoint)]</InArgument></Assign.Value>
                  </Assign>

                  <Assign DisplayName="Execute HTTP call (status|body)">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_CombinedResult]</OutArgument></Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">(Function()
    Dim client As New System.Net.Http.HttpClient()
    client.Timeout = TimeSpan.FromSeconds(60)
    Dim req As New System.Net.Http.HttpRequestMessage(New System.Net.Http.HttpMethod(in_Method.ToUpper()), v_Url)
    req.Headers.TryAddWithoutValidation("Authorization", "Bearer " &amp; in_Token)
    req.Headers.TryAddWithoutValidation("Accept", "application/json")
    If Not String.IsNullOrEmpty(in_FolderId) Then req.Headers.TryAddWithoutValidation("X-UIPATH-OrganizationUnitId", in_FolderId)
    If Not String.IsNullOrEmpty(in_RequestBody) AndAlso (in_Method.ToUpper() = "POST" OrElse in_Method.ToUpper() = "PUT") Then
        req.Content = New System.Net.Http.StringContent(in_RequestBody, System.Text.Encoding.UTF8, "application/json")
    End If
    Dim resp As System.Net.Http.HttpResponseMessage = client.SendAsync(req).Result
    Dim statusCode As Integer = CInt(resp.StatusCode)
    Dim body As String = resp.Content.ReadAsStringAsync().Result
    If Not resp.IsSuccessStatusCode Then
        Throw New Exception("HTTP " &amp; statusCode.ToString() &amp; " on " &amp; in_Method &amp; " " &amp; v_Url &amp; ": " &amp; body)
    End If
    Return statusCode.ToString().PadLeft(3, "0"c) &amp; body
End Function)()</InArgument>
                    </Assign.Value>
                  </Assign>

                  <Assign DisplayName="Extract status code">
                    <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_LastStatus]</OutArgument></Assign.To>
                    <Assign.Value><InArgument x:TypeArguments="x:Int32">[CInt(v_CombinedResult.Substring(0, 3))]</InArgument></Assign.Value>
                  </Assign>
                  <Assign DisplayName="Extract response body">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_LastBody]</OutArgument></Assign.To>
                    <Assign.Value><InArgument x:TypeArguments="x:String">[v_CombinedResult.Substring(3)]</InArgument></Assign.Value>
                  </Assign>

                  <If Condition="[in_Method.ToUpper() = &quot;GET&quot;]" DisplayName="GET pagination">
                    <If.Then>
                      <Sequence DisplayName="Process GET page">
                        <Assign DisplayName="Count page items">
                          <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_PageCount]</OutArgument></Assign.To>
                          <Assign.Value><InArgument x:TypeArguments="x:Int32">[If(JObject.Parse(v_LastBody)("value") IsNot Nothing, DirectCast(JObject.Parse(v_LastBody)("value"), JArray).Count, 0)]</InArgument></Assign.Value>
                        </Assign>
                        <Assign DisplayName="Merge items into accumulator">
                          <Assign.To><OutArgument x:TypeArguments="x:String">[v_AllItemsJson]</OutArgument></Assign.To>
                          <Assign.Value>
                            <InArgument x:TypeArguments="x:String">(Function()
    Dim existing As JArray = JArray.Parse(v_AllItemsJson)
    Dim pageToken As JToken = JObject.Parse(v_LastBody)("value")
    If pageToken IsNot Nothing Then
        For Each item As JToken In DirectCast(pageToken, JArray)
            existing.Add(item)
        Next
    End If
    Return existing.ToString()
End Function)()</InArgument>
                          </Assign.Value>
                        </Assign>
                        <Assign DisplayName="Advance skip">
                          <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_Skip]</OutArgument></Assign.To>
                          <Assign.Value><InArgument x:TypeArguments="x:Int32">[v_Skip + 100]</InArgument></Assign.Value>
                        </Assign>
                        <Assign DisplayName="Set hasMore">
                          <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_HasMore]</OutArgument></Assign.To>
                          <Assign.Value><InArgument x:TypeArguments="x:Boolean">[v_PageCount = 100]</InArgument></Assign.Value>
                        </Assign>
                      </Sequence>
                    </If.Then>
                    <If.Else>
                      <Assign DisplayName="Stop loop (non-GET)">
                        <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_HasMore]</OutArgument></Assign.To>
                        <Assign.Value><InArgument x:TypeArguments="x:Boolean">False</InArgument></Assign.Value>
                      </Assign>
                    </If.Else>
                  </If>

                </Sequence>
              </While>

              <Assign DisplayName="Set out_StatusCode">
                <Assign.To><OutArgument x:TypeArguments="x:Int32">[out_StatusCode]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Int32">[v_LastStatus]</InArgument></Assign.Value>
              </Assign>
              <Assign DisplayName="Set out_ResponseJson">
                <Assign.To><OutArgument x:TypeArguments="x:String">[out_ResponseJson]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">[If(in_Method.ToUpper() = "GET", v_AllItemsJson, v_LastBody)]</InArgument></Assign.Value>
              </Assign>
              <Assign DisplayName="Mark Success">
                <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_Success]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:Boolean">True</InArgument></Assign.Value>
              </Assign>
            </Sequence>
          </TryCatch.Try>
          <TryCatch.Catches>
            <Catch x:TypeArguments="s:Exception">
              <ActivityAction x:TypeArguments="s:Exception">
                <ActivityAction.Argument>
                  <DelegateInArgument x:TypeArguments="s:Exception" Name="apiEx" />
                </ActivityAction.Argument>
                <Sequence DisplayName="Handle API Error">
                  <Assign DisplayName="Store Error">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[v_LastError]</OutArgument></Assign.To>
                    <Assign.Value><InArgument x:TypeArguments="x:String">[apiEx.Message]</InArgument></Assign.Value>
                  </Assign>
                  <ui:LogMessage Level="Warn" Message="[&quot;[API] Attempt &quot; &amp; v_RetryCount.ToString() &amp; &quot; failed: &quot; &amp; v_LastError]" DisplayName="Log: Retry Warning" />
                  <If DisplayName="If More Retries Remain">
                    <If.Condition>[v_RetryCount &lt; 3]</If.Condition>
                    <If.Then>
                      <Assign DisplayName="Wait 5s before retry">
                        <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
                        <Assign.Value>
                          <InArgument x:TypeArguments="x:String">(Function()
    System.Threading.Thread.Sleep(5000)
    Return ""
End Function)()</InArgument>
                        </Assign.Value>
                      </Assign>
                    </If.Then>
                    <If.Else>
                      <Throw DisplayName="Rethrow After Max Retries">
                        <Throw.Exception>
                          <InArgument x:TypeArguments="s:Exception">[New Exception("[API] All 3 retry attempts failed. Last error: " &amp; v_LastError)]</InArgument>
                        </Throw.Exception>
                      </Throw>
                    </If.Else>
                  </If>
                </Sequence>
              </ActivityAction>
            </Catch>
          </TryCatch.Catches>
        </TryCatch>
      </Sequence>
    </While>
  </Sequence>
</Activity>
