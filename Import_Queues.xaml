<Activity mc:Ignorable="sap sap2010" x:Class="Import_Queues" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_TargetBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_TargetToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 4 - Queues">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_QueuesJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderMappingJson" Default="&quot;{}&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="[UiPath.Core.LogLevel.Info]" Message="&quot;[Import Queues] Creating queue definitions in target folders...&quot;" DisplayName="Log: Start" />

    <ui:InvokeCode Language="VisualBasic" DisplayName="Read Input Files">
      <ui:InvokeCode.Code>
        <![CDATA[
v_QueuesJson = System.IO.File.ReadAllText(
    System.IO.Path.Combine(in_DataPath, "Export_Queues.json"), System.Text.Encoding.UTF8)
v_FolderMappingJson = System.IO.File.ReadAllText(
    System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json"), System.Text.Encoding.UTF8)
        ]]>
      </ui:InvokeCode.Code>
    </ui:InvokeCode>

    <ui:InvokeCode Language="VisualBasic" DisplayName="Create Queue Definitions in Target">
      <ui:InvokeCode.Code>
        <![CDATA[
Dim queues As Newtonsoft.Json.Linq.JArray = Newtonsoft.Json.Linq.JArray.Parse(v_QueuesJson)
Dim folderIdMap As Newtonsoft.Json.Linq.JObject = Newtonsoft.Json.Linq.JObject.Parse(v_FolderMappingJson)

Dim httpClient As New System.Net.Http.HttpClient()
httpClient.Timeout = TimeSpan.FromSeconds(60)

Dim created As Integer = 0
Dim skipped As Integer = 0
Dim failed As Integer = 0

For Each queue As Newtonsoft.Json.Linq.JObject In queues
    Dim srcFolderId As String = If(queue("_SourceFolderId") IsNot Nothing,
        queue("_SourceFolderId").ToString(), "")
    Dim queueName As String = queue("Name").ToString()

    Dim targetFolderId As String = ""
    If folderIdMap(srcFolderId) IsNot Nothing Then
        targetFolderId = folderIdMap(srcFolderId).ToString()
    Else
        Console.WriteLine("[Import Queues] WARNING: No folder mapping for source folder " &
            srcFolderId & ". Skipping queue: " & queueName)
        failed += 1
        Continue For
    End If

    ' Build POST body with all queue definition properties
    Dim body As New Newtonsoft.Json.Linq.JObject()
    body("Name") = queueName
    body("Description") = If(queue("Description") IsNot Nothing AndAlso
        queue("Description").Type <> Newtonsoft.Json.Linq.JTokenType.Null,
        queue("Description").ToString(), "")
    body("MaxNumberOfRetries") = If(queue("MaxNumberOfRetries") IsNot Nothing,
        CInt(queue("MaxNumberOfRetries")), 0)
    body("AcceptAutomaticallyRetry") = If(queue("AcceptAutomaticallyRetry") IsNot Nothing,
        CBool(queue("AcceptAutomaticallyRetry")), False)
    body("EnforceUniqueReference") = If(queue("EnforceUniqueReference") IsNot Nothing,
        CBool(queue("EnforceUniqueReference")), False)

    If queue("SpecificDataJsonSchema") IsNot Nothing AndAlso
       queue("SpecificDataJsonSchema").Type <> Newtonsoft.Json.Linq.JTokenType.Null Then
        body("SpecificDataJsonSchema") = queue("SpecificDataJsonSchema").ToString()
    End If

    If queue("SlaInMinutes") IsNot Nothing AndAlso
       queue("SlaInMinutes").Type <> Newtonsoft.Json.Linq.JTokenType.Null Then
        body("SlaInMinutes") = CInt(queue("SlaInMinutes"))
    End If
    If queue("RiskSlaInMinutes") IsNot Nothing AndAlso
       queue("RiskSlaInMinutes").Type <> Newtonsoft.Json.Linq.JTokenType.Null Then
        body("RiskSlaInMinutes") = CInt(queue("RiskSlaInMinutes"))
    End If

    Try
        Dim postUrl As String = in_TargetBaseUrl.TrimEnd("/"c) & "/odata/QueueDefinitions"
        Dim postReq As New System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Post, postUrl)
        postReq.Headers.TryAddWithoutValidation("Authorization", "Bearer " & in_TargetToken)
        postReq.Headers.TryAddWithoutValidation("Accept", "application/json")
        postReq.Headers.TryAddWithoutValidation("X-UIPATH-OrganizationUnitId", targetFolderId)
        postReq.Content = New System.Net.Http.StringContent(
            body.ToString(), System.Text.Encoding.UTF8, "application/json")

        Dim postResp As System.Net.Http.HttpResponseMessage = httpClient.SendAsync(postReq).Result
        Dim postBody As String = postResp.Content.ReadAsStringAsync().Result

        If postResp.IsSuccessStatusCode Then
            created += 1
        ElseIf CInt(postResp.StatusCode) = 409 Then
            ' Conflict = queue already exists, skip gracefully
            Console.WriteLine("[Import Queues] Queue already exists (skipping): " & queueName)
            skipped += 1
        Else
            Console.WriteLine("[Import Queues] WARNING: Failed to create queue '" & queueName &
                "': HTTP " & CInt(postResp.StatusCode).ToString() & " - " & postBody)
            failed += 1
        End If
    Catch ex As Exception
        Console.WriteLine("[Import Queues] ERROR for queue '" & queueName & "': " & ex.Message)
        failed += 1
    End Try
Next

Console.WriteLine("[Import Queues] Created: " & created & ", Skipped (duplicate): " & skipped &
    ", Failed: " & failed)
        ]]>
      </ui:InvokeCode.Code>
    </ui:InvokeCode>

    <ui:LogMessage Level="[UiPath.Core.LogLevel.Info]" Message="&quot;[Import Queues] Queue definitions import complete.&quot;" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
