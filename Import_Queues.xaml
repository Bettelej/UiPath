<Activity mc:Ignorable="sap sap2010" x:Class="Import_Queues" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
      <AssemblyReference>System.Private.Uri</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_TargetBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_TargetToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Import Step 4 - Queues">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_QueuesJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderMappingJson" Default="&quot;{}&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Queues] Creating queue definitions in target folders...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Queues.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_QueuesJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Queues.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Read FolderIdMapping.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderMappingJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "FolderIdMapping.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="Create Queue Definitions in Target">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    Dim queues As JArray = JArray.Parse(v_QueuesJson)
    Dim folderIdMap As JObject = JObject.Parse(v_FolderMappingJson)

    Dim httpClient As New System.Net.Http.HttpClient()
    httpClient.Timeout = TimeSpan.FromSeconds(60)

    For Each queue As JObject In queues
        Dim srcFolderId As String = If(queue("_SourceFolderId") IsNot Nothing, queue("_SourceFolderId").ToString(), "")
        Dim queueName As String = queue("Name").ToString()

        Dim targetFolderId As String = ""
        If folderIdMap(srcFolderId) IsNot Nothing Then
            targetFolderId = folderIdMap(srcFolderId).ToString()
        Else
            Console.WriteLine("[Import Queues] WARNING: No folder mapping for source folder " &amp; srcFolderId &amp; ". Skipping queue: " &amp; queueName)
            Continue For
        End If

        Dim body As New JObject()
        body("Name") = queueName
        body("Description") = If(queue("Description") IsNot Nothing AndAlso queue("Description").Type &lt;> JTokenType.Null, queue("Description").ToString(), "")
        body("MaxNumberOfRetries") = If(queue("MaxNumberOfRetries") IsNot Nothing, CInt(queue("MaxNumberOfRetries")), 0)
        body("AcceptAutomaticallyRetry") = If(queue("AcceptAutomaticallyRetry") IsNot Nothing, CBool(queue("AcceptAutomaticallyRetry")), False)
        body("EnforceUniqueReference") = If(queue("EnforceUniqueReference") IsNot Nothing, CBool(queue("EnforceUniqueReference")), False)

        If queue("SpecificDataJsonSchema") IsNot Nothing AndAlso queue("SpecificDataJsonSchema").Type &lt;> JTokenType.Null Then
            body("SpecificDataJsonSchema") = queue("SpecificDataJsonSchema").ToString()
        End If
        If queue("SlaInMinutes") IsNot Nothing AndAlso queue("SlaInMinutes").Type &lt;> JTokenType.Null Then
            body("SlaInMinutes") = CInt(queue("SlaInMinutes"))
        End If
        If queue("RiskSlaInMinutes") IsNot Nothing AndAlso queue("RiskSlaInMinutes").Type &lt;> JTokenType.Null Then
            body("RiskSlaInMinutes") = CInt(queue("RiskSlaInMinutes"))
        End If

        Try
            Dim postUrl As String = in_TargetBaseUrl.TrimEnd("/"c) &amp; "/odata/QueueDefinitions"
            Dim postReq As New System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Post, postUrl)
            postReq.Headers.TryAddWithoutValidation("Authorization", "Bearer " &amp; in_TargetToken)
            postReq.Headers.TryAddWithoutValidation("Accept", "application/json")
            postReq.Headers.TryAddWithoutValidation("X-UIPATH-OrganizationUnitId", targetFolderId)
            postReq.Content = New System.Net.Http.StringContent(body.ToString(), System.Text.Encoding.UTF8, "application/json")

            Dim postResp As System.Net.Http.HttpResponseMessage = httpClient.SendAsync(postReq).Result
            Dim postBody As String = postResp.Content.ReadAsStringAsync().Result

            If postResp.IsSuccessStatusCode Then
                Console.WriteLine("[Import Queues] Created queue: " &amp; queueName)
            ElseIf CInt(postResp.StatusCode) = 409 Then
                Console.WriteLine("[Import Queues] Queue already exists (skipping): " &amp; queueName)
            Else
                Console.WriteLine("[Import Queues] WARNING: Failed to create queue '" &amp; queueName &amp;
                    "': HTTP " &amp; CInt(postResp.StatusCode).ToString() &amp; " - " &amp; postBody)
            End If
        Catch ex As Exception
            Console.WriteLine("[Import Queues] ERROR for queue '" &amp; queueName &amp; "': " &amp; ex.Message)
        End Try
    Next

    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info" Message="[&quot;[Import Queues] Queue definitions import complete.&quot;]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
