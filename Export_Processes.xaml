<Activity mc:Ignorable="sap sap2010" x:Class="Export_Processes" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:nj="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Export Step 7 - Processes">
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_FoldersJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_AllItemsJson" Default="&quot;[]&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_PageResponse" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
      <Variable x:TypeArguments="x:Int32" Name="v_Skip" Default="0" />
      <Variable x:TypeArguments="x:Boolean" Name="v_HasMore" Default="True" />
      <Variable x:TypeArguments="x:Int32" Name="v_PageCount" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_FolderId" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_FolderName" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_OutputPath" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Export Processes] Reading folder list and fetching releases per folder...&quot;]" DisplayName="Log: Start" />

    <Assign DisplayName="Read Export_Folders.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_FoldersJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.File.ReadAllText(System.IO.Path.Combine(in_DataPath, "Export_Folders.json"), System.Text.Encoding.UTF8)]</InArgument></Assign.Value>
    </Assign>

    <ForEach x:TypeArguments="nj:JToken" DisplayName="ForEach Folder" Values="[JArray.Parse(v_FoldersJson)]">
      <ForEach.Body>
        <ActivityAction x:TypeArguments="nj:JToken">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="nj:JToken" Name="folderToken" />
          </ActivityAction.Argument>
          <Sequence DisplayName="Process Folder">
            <Assign DisplayName="Set FolderId">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderId]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[folderToken("Id").ToString()]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Set FolderName">
              <Assign.To><OutArgument x:TypeArguments="x:String">[v_FolderName]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">[If(folderToken("FullyQualifiedName") IsNot Nothing AndAlso folderToken("FullyQualifiedName").Type &lt;> JTokenType.Null, folderToken("FullyQualifiedName").ToString(), folderToken("DisplayName").ToString())]</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Reset Skip">
              <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_Skip]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:Int32">0</InArgument></Assign.Value>
            </Assign>
            <Assign DisplayName="Reset HasMore">
              <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_HasMore]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:Boolean">True</InArgument></Assign.Value>
            </Assign>
            <While DisplayName="Pagination Loop">
              <While.Condition>[v_HasMore]</While.Condition>
              <Sequence DisplayName="Fetch One Page">
                <ui:OrchestratorHttpRequest DisplayName="GET /odata/Releases for folder" Method="GET">
                  <ui:OrchestratorHttpRequest.Endpoint>
                    <InArgument x:TypeArguments="x:String">["/odata/Releases?$top=100&amp;$skip=" &amp; v_Skip.ToString()]</InArgument>
                  </ui:OrchestratorHttpRequest.Endpoint>
                  <ui:OrchestratorHttpRequest.OrganizationUnitId>
                    <InArgument x:TypeArguments="x:Int64">[CLng(v_FolderId)]</InArgument>
                  </ui:OrchestratorHttpRequest.OrganizationUnitId>
                  <ui:OrchestratorHttpRequest.Response>
                    <OutArgument x:TypeArguments="x:String">[v_PageResponse]</OutArgument>
                  </ui:OrchestratorHttpRequest.Response>
                  <ui:OrchestratorHttpRequest.StatusCode>
                    <OutArgument x:TypeArguments="x:Int32">[v_StatusCode]</OutArgument>
                  </ui:OrchestratorHttpRequest.StatusCode>
                </ui:OrchestratorHttpRequest>
                <Assign DisplayName="Count page items">
                  <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_PageCount]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:Int32">[If(JObject.Parse(v_PageResponse)("value") IsNot Nothing, DirectCast(JObject.Parse(v_PageResponse)("value"), JArray).Count, 0)]</InArgument></Assign.Value>
                </Assign>
                <Assign DisplayName="Merge items with folder metadata">
                  <Assign.To><OutArgument x:TypeArguments="x:String">[v_AllItemsJson]</OutArgument></Assign.To>
                  <Assign.Value>
                    <InArgument x:TypeArguments="x:String">(Function()
    Dim allItems As JArray = JArray.Parse(v_AllItemsJson)
    Dim obj As JObject = JObject.Parse(v_PageResponse)
    Dim pageItems As JArray = TryCast(obj("value"), JArray)
    If pageItems IsNot Nothing Then
        For Each item As JObject In pageItems
            item("_SourceFolderId") = v_FolderId
            item("_SourceFolderName") = v_FolderName
            allItems.Add(item)
        Next
    End If
    Return allItems.ToString()
End Function)()</InArgument>
                  </Assign.Value>
                </Assign>
                <Assign DisplayName="Advance skip">
                  <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_Skip]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:Int32">[v_Skip + 100]</InArgument></Assign.Value>
                </Assign>
                <Assign DisplayName="Set HasMore">
                  <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_HasMore]</OutArgument></Assign.To>
                  <Assign.Value><InArgument x:TypeArguments="x:Boolean">[v_PageCount = 100]</InArgument></Assign.Value>
                </Assign>
              </Sequence>
            </While>
          </Sequence>
        </ActivityAction>
      </ForEach.Body>
    </ForEach>

    <Assign DisplayName="Set Output Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_OutputPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Export_Processes.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Save Export_Processes.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    System.IO.File.WriteAllText(v_OutputPath, JArray.Parse(v_AllItemsJson).ToString(Formatting.Indented), System.Text.Encoding.UTF8)
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>
    <ui:LogMessage Level="Info" Message="[&quot;[Export Processes] Saved &quot; &amp; JArray.Parse(v_AllItemsJson).Count.ToString() &amp; &quot; releases to &quot; &amp; v_OutputPath]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>