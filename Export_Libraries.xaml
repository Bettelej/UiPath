<Activity mc:Ignorable="sap sap2010" x:Class="Export_Libraries" VisualBasic.Settings="{x:Null}" sap2010:WorkflowViewState.IdRef="ActivityBuilder_1"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.IO</x:String>
      <x:String>System.Text</x:String>
      <x:String>System.Net.Http</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>Newtonsoft.Json</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
      <x:String>UiPath.Core</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System.Net.Http</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
      <AssemblyReference>System.Private.Uri</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <x:Members>
    <x:Property Name="in_SourceBaseUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_SourceToken" Type="InArgument(x:String)" />
    <x:Property Name="in_DataPath" Type="InArgument(x:String)" />
  </x:Members>
  <Sequence DisplayName="Export Step 6 - Libraries">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_ResponseJson" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:Int32" Name="v_StatusCode" Default="0" />
      <Variable x:TypeArguments="x:String" Name="v_OutputPath" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_LibrariesDir" Default="&quot;&quot;" />
      <Variable x:TypeArguments="x:String" Name="v_Dummy" Default="&quot;&quot;" />
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[&quot;[Export Libraries] Fetching library list from source (tenant-level)...&quot;]" DisplayName="Log: Start" />

    <ui:InvokeWorkflowFile WorkflowFileName="Shared_OrchestratorApiCall.xaml" DisplayName="GET /odata/Libraries">
      <ui:InvokeWorkflowFile.Arguments>
        <scg:Dictionary x:TypeArguments="x:String, Argument">
          <InArgument x:TypeArguments="x:String" x:Key="in_BaseUrl">[in_SourceBaseUrl]</InArgument>
          <InArgument x:TypeArguments="x:String" x:Key="in_Token">[in_SourceToken]</InArgument>
          <InArgument x:TypeArguments="x:String" x:Key="in_Endpoint">"/odata/Libraries"</InArgument>
          <InArgument x:TypeArguments="x:String" x:Key="in_Method">"GET"</InArgument>
          <InArgument x:TypeArguments="x:String" x:Key="in_FolderId">""</InArgument>
          <InArgument x:TypeArguments="x:String" x:Key="in_RequestBody">""</InArgument>
          <OutArgument x:TypeArguments="x:String" x:Key="out_ResponseJson">[v_ResponseJson]</OutArgument>
          <OutArgument x:TypeArguments="x:Int32" x:Key="out_StatusCode">[v_StatusCode]</OutArgument>
        </scg:Dictionary>
      </ui:InvokeWorkflowFile.Arguments>
    </ui:InvokeWorkflowFile>

    <Assign DisplayName="Set Output Path">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_OutputPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Export_Libraries.json")]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set Libraries Dir">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_LibrariesDir]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_DataPath, "Libraries")]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="Save Export_Libraries.json">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    System.IO.File.WriteAllText(v_OutputPath, JArray.Parse(v_ResponseJson).ToString(Formatting.Indented), System.Text.Encoding.UTF8)
    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info" Message="[&quot;[Export Libraries] Downloading .nupkg files to &quot; &amp; v_LibrariesDir]" DisplayName="Log: Downloading" />

    <Assign DisplayName="Download Library .nupkg Files">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Dummy]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">(Function()
    Dim libs As JArray = JArray.Parse(v_ResponseJson)
    Dim httpClient As New System.Net.Http.HttpClient()
    httpClient.Timeout = TimeSpan.FromMinutes(10)
    httpClient.DefaultRequestHeaders.TryAddWithoutValidation("Authorization", "Bearer " &amp; in_SourceToken)

    For Each lib As JObject In libs
        Dim libId As String = lib("Id").ToString()
        Dim parts() As String = libId.Split(":"c)
        Dim libName As String = parts(0)
        Dim libVersion As String = If(parts.Length > 1, parts(1), "")

        Dim fileName As String = libName &amp; "." &amp; libVersion &amp; ".nupkg"
        Dim filePath As String = System.IO.Path.Combine(v_LibrariesDir, fileName)

        If System.IO.File.Exists(filePath) Then
            Continue For
        End If

        Try
            Dim url As String = in_SourceBaseUrl.TrimEnd("/"c) &amp;
                "/odata/Libraries/UiPath.Server.Configuration.OData.DownloadPackage(key='" &amp;
                libName &amp; "',version='" &amp; libVersion &amp; "')"

            Dim bytes() As Byte = httpClient.GetByteArrayAsync(url).Result
            System.IO.File.WriteAllBytes(filePath, bytes)
        Catch ex As Exception
            Console.WriteLine("[Export Libraries] WARNING: Failed to download " &amp; libId &amp; ": " &amp; ex.Message)
        End Try
    Next

    Return ""
End Function)()</InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info" Message="[&quot;[Export Libraries] Complete. Libraries saved to &quot; &amp; v_LibrariesDir]" DisplayName="Log: Complete" />
  </Sequence>
</Activity>
